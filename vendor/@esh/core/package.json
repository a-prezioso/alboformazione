    },
    "./list": {
      "types": "./dist/components/list/index.d.ts",
      "import": "./dist/components/list/index.js"
    },
    "./pagination": {
      "types": "./dist/components/pagination/index.d.ts",
      "import": "./dist/components/pagination/index.js"
    },
    "./fab": {
      "types": "./dist/components/fab/index.d.ts",
