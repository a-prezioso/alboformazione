  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "@esh/tokens": "^1.2.1"
  },
  "dependencies": {
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.9.0",
    "axe-core": "^4.9.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0",
    "jsdom": "^24.0.0",
    "@open-wc/testing": "^4.0.0",
    "@esh/tokens": "1.2.1"
  },
  "scripts": {
    "build": "vite build && node -e \"require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})\" && tsc --emitDeclarationOnly && node ../../scripts/emit-component-stubs.mjs . && npm run analyze",
    "dev": "vite build --watch",
    "lint": "eslint \"src/**/*.ts\" && stylelint \"src/**/*.css\" --allow-empty-input",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "cem analyze --config custom-elements-manifest.config.js",
    "analyze:watch": "cem analyze --config custom-elements-manifest.config.js --watch",
    "gen:component": "node ../../scripts/gen-component.mjs",
    "clean": "rm -rf dist"
  }
}