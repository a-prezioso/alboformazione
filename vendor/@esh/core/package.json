{
  "name": "@esh/core",
  "version": "1.2.1",
  "description": "ESH Design System — web components (Lit + TypeScript). Universali: funzionano in HTML, Thymeleaf, Angular, React, Vue, Svelte.",
  "author": "Elite Software House",
  "license": "UNLICENSED",
  "type": "module",
  "publishConfig": {
    "access": "restricted"
  },
  "sideEffects": [
    "./dist/**/*.js"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "customElements": "./dist/custom-elements.json",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/components/button/index.js"
    },
