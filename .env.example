# Albo Formazione — variabili d'ambiente (tutte OPZIONALI in locale)
#
# In locale NON serve configurare nulla: l'app usa un database Postgres
# embedded (PGlite) creato e popolato automaticamente al primo `pnpm dev`.
# Copia questo file in `.env.local` solo se vuoi sovrascrivere i default.

# --- Database ---
# Lascia VUOTO per usare il DB embedded locale (default, nessun server richiesto).
# Imposta un URL postgres:// per puntare a un Postgres reale (es. produzione).
# DATABASE_URL=
# Cartella dei dati del DB embedded (default: <root>/.localdb)
# PGLITE_DIR=

# --- Funzioni AI (generazione domande quiz nel backoffice) ---
# Senza chiave, la funzione AI risponde con uno stub: l'app resta pienamente usabile.
# AI_GATEWAY_URL=
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_TENANT=alboformazione

# --- Email (notifiche) ---
# Senza SMTP le email non vengono inviate; nessun impatto sui flussi demo.
# MAIL_ENABLED=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=Albo Formazione <no-reply@example.com>

# --- Varie ---
# APP_BASE_URL=http://localhost:3000
# ADAPTER_MODE=mock
