{
  "name": "alboformazione",
  "version": "0.0.0",
  "private": true,
  "description": "Albo Formazione — LMS white-label per Associazioni Professionali (Live + Differita, crediti, attestati, e-commerce, backoffice)",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "node scripts/ensure-db.mjs && turbo run dev",
    "setup:local": "node scripts/ensure-db.mjs",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @alboformazione/db db:migrate",
    "db:seed": "pnpm --filter @alboformazione/db db:seed",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.22.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  }
}
